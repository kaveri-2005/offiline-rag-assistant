{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "npm run start-all",
    "start-all": "concurrently \"cd Backend && npm run dev\" \"cd Frontend && npm run dev\"",
    "install-all": "npm install && cd Backend && npm install && cd ../Frontend && npm install"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^9.1.5",
    "ollama": "^0.6.3",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}